# Build Stage
FROM node:20-alpine AS builder
WORKDIR /app

COPY web/package*.json ./
RUN npm ci

COPY web/ ./
# registry.json di-import relatif dari shared/ — copy ikut build context monorepo
COPY shared/agents/registry.json /shared/agents/registry.json

RUN npm run build

# Production Stage
FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
COPY deploy/docker/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
