# Core Configurations
PORT=8080
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=joki_tugas
MONGO_TIMEOUT_SECONDS=10
APP_ENV=development
JWT_SECRET=change_me_in_production

# LLM Configurations
DEEPSEEK_API_KEY=

# LLM — OpenCode Go (OpenAI-compatible)
OPENCODE_GO_API_KEY=
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_MODEL=deepseek-v4-flash

# Runner Settings
REQUEST_TIMEOUT_MS=120000

# Chat quota (lifetime messages per account). Dev: 50, Prod: 5
CHAT_LIMIT=50

# Web search (topic → URL sebelum web_scraper). OpenCode Go TIDAK punya web search bawaan.
# wikipedia = gratis & stabil (default) | brave = Brave Search API (lebih luas) | duckduckgo | off
WEB_SEARCH_PROVIDER=wikipedia
WEB_SEARCH_MAX_RESULTS=3
BRAVE_SEARCH_API_KEY=

# Agent Node Simulation Mode (Set true for mock run offline, false to call real endpoints)
SIMULATE_AGENTS=false

# Per-agent soft-fail policy lives in shared/agents/registry.json (onError: stop|skip).
# stop = fail whole pipeline; skip = continue if next step still type-compatible.

# Agent Endpoints Configuration (Used when SIMULATE_AGENTS=false)
# Env key names are defined in shared/agents/registry.json → envUrl
AGENT_CITATION_REFERENCE_URL=https://dummy-agent-url.com/api
AGENT_TRANSLATOR_URL=https://dummy-agent-url.com/api
AGENT_PARAPHRASE_URL=https://dummy-agent-url.com/api
