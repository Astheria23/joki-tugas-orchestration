# Core Configurations
PORT=8080
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=joki_tugas
MONGO_TIMEOUT_SECONDS=10
APP_ENV=development
JWT_SECRET=change_me_in_production

# LLM — OpenCode Go (OpenAI-compatible)
# Get key from OpenCode Zen console after subscribing to Go
OPENCODE_GO_API_KEY=your_opencode_go_api_key_here
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_MODEL=deepseek-v4-flash

# Runner Settings
REQUEST_TIMEOUT_MS=30000

# Chat quota (lifetime messages per account). Local/dev: 50, production: 5
CHAT_LIMIT=50

# Agent Node Simulation Mode (Set true for mock run offline, false to call real endpoints)
SIMULATE_AGENTS=true

# Agent Endpoints Configuration (Used when SIMULATE_AGENTS=false)
AGENT_CITATION_REFERENCE_URL=https://api-sam.com/v1/execute
AGENT_TRANSLATOR_URL=https://kal-translator.up.railway.app/process
AGENT_PARAPHRASE_URL=https://piol-parafrase.my.id/api
AGENT_DATABASE_QUERIER_URL=https://adit-db.herokuapp.com/query
AGENT_SUMMARIZER_URL=https://qila-summarizer.vercel.app/api/run
AGENT_OUTLINER_URL=https://eka-outliner.fly.dev/generate
AGENT_QNA_SIMULATOR_URL=https://ferdy-qna.com/ask
AGENT_PPT_GENERATOR_URL=https://indra-ppt.my.id/generate
AGENT_PROGRAMMER_URL=https://aghni-coder.up.railway.app/code
AGENT_REQUIREMENT_ANALYZER_URL=https://srh-analyzer.com/analyze
AGENT_DIAGRAM_BUILDER_URL=https://ahmad-diagram.my.id/build
AGENT_FACT_CHECKER_URL=https://zif-fact.com/check
AGENT_TYPO_CHECKER_URL=https://dina-typo.vercel.app/fix
AGENT_DATA_MINING_URL=https://dwi-mining.fly.dev/mine
AGENT_PR_REVIEWER_URL=https://fadel-pr.com/review
AGENT_PDF_FORMATTER_URL=https://restu-pdf.herokuapp.com/format
AGENT_WEB_SCRAPER_URL=https://scraper.fly.dev/scrape
AGENT_LITERATURE_REVIEWER_URL=https://lit-reviewer.my.id/review
AGENT_CONTEXT_MEMORY_URL=https://context.vercel.app/store
AGENT_SUPERVISOR_URL=https://supervisor-qc.up.railway.app/check
AGENT_MATH_CALCULATOR_URL=https://math-calc.herokuapp.com/solve
AGENT_SPATIAL_GIS_URL=https://gis-spatial.com/process
