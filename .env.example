# Core Configurations
PORT=8080
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=joki_tugas
MONGO_TIMEOUT_SECONDS=10
APP_ENV=development
JWT_SECRET=change_me_in_production

# LLM — OpenCode Go (OpenAI-compatible)
# Get key from OpenCode Zen console after subscribing to Go
OPENCODE_GO_API_KEY=your_opencode_go_api_key_here
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_MODEL=deepseek-v4-flash

# Runner Settings
REQUEST_TIMEOUT_MS=30000

# Chat quota (lifetime messages per account). Local/dev: 50, production: 5
CHAT_LIMIT=50

# Agent Node Simulation Mode (Set true for mock run offline, false to call real endpoints)
SIMULATE_AGENTS=true

# Agent Endpoints Configuration (Used when SIMULATE_AGENTS=false)
AGENT_CITATION_REFERENCE_URL=https://citation-agent.example.com/api
AGENT_TRANSLATOR_URL=https://translator-agent.example.com/api
AGENT_PARAPHRASE_URL=https://paraphrase-agent.example.com/api
AGENT_DATABASE_QUERIER_URL=https://database-agent.example.com/api
AGENT_SUMMARIZER_URL=https://summarizer-agent.example.com/api
AGENT_OUTLINER_URL=https://outliner-agent.example.com/api
AGENT_QNA_SIMULATOR_URL=https://qna-agent.example.com/api
AGENT_PPT_GENERATOR_URL=https://ppt-agent.example.com/api
AGENT_PROGRAMMER_URL=https://programmer-agent.example.com/api
AGENT_REQUIREMENT_ANALYZER_URL=https://analyzer-agent.example.com/api
AGENT_DIAGRAM_BUILDER_URL=https://diagram-agent.example.com/api
AGENT_FACT_CHECKER_URL=https://factcheck-agent.example.com/api
AGENT_TYPO_CHECKER_URL=https://typo-agent.example.com/api
AGENT_DATA_MINING_URL=https://datamining-agent.example.com/api
AGENT_PR_REVIEWER_URL=https://prreviewer-agent.example.com/api
AGENT_PDF_FORMATTER_URL=https://pdf-agent.example.com/api
AGENT_WEB_SCRAPER_URL=http://localhost:5000/scrape
AGENT_LITERATURE_REVIEWER_URL=https://litreview-agent.example.com/api
AGENT_CONTEXT_MEMORY_URL=https://context-agent.example.com/api
AGENT_SUPERVISOR_URL=https://supervisor-agent.example.com/api
AGENT_MATH_CALCULATOR_URL=https://math-agent.example.com/api
AGENT_SPATIAL_GIS_URL=https://gis-agent.example.com/api
